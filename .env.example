# ── Proxmox Connection ────────────────────────────────────────────────────
# IP or hostname of your Proxmox node (no protocol, no port)
PVE_HOST=192.168.1.10

# Proxmox web UI port (default 8006)
PVE_PORT=8006

# API Token ID — format: user@realm!tokenname
# Create in PVE UI: Datacenter > API Tokens > Add
PVE_TOKEN_ID=root@pam!dashboard

# API Token Secret (the UUID shown once at creation)
PVE_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Dashboard Settings ────────────────────────────────────────────────────
# Port this web app listens on
PORT=3000

# How many seconds to cache Proxmox API responses (reduces load on server)
CACHE_TTL=10

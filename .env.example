# ==== Proxmox connection ====================================================
# IP or hostname of your Proxmox node (no protocol, no port)
PVE_HOST=192.168.1.10

# Proxmox web UI port (default 8006)
PVE_PORT=8006

# API Token ID. Format: user@realm!tokenname
# Create in PVE UI: Datacenter > Permissions > API Tokens > Add
# The token user only needs PVEAuditor on / (read-only).
PVE_TOKEN_ID=root@pam!vitals

# API Token Secret (UUID shown once at creation)
PVE_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ==== App settings ==========================================================
# Port this wall display listens on
PORT=3000

# Seconds to cache Proxmox API responses (reduces load on your PVE cluster)
CACHE_TTL=10

# Default UI language when the browser language cannot be detected: en or de
DEFAULT_LANG=en

# Force a UI language regardless of browser. Options: en, de. Empty = auto.
# URL override via ?lang=de|en still works for ad-hoc testing.
FORCE_LANG=

# Auto-scroll long panel lists every N seconds. 0 disables. Default: 15.
# Pauses when the mouse hovers over a panel and when content fits without
# overflow. Respects prefers-reduced-motion.
AUTO_SCROLL_INTERVAL=15

# Play a short alert beep when overall health transitions into CRIT.
# Requires a one-time user click or key press on the page to unlock audio.
ENABLE_SOUND=false

# UI theme. Keys:
#   professional (default)    - sleek product-grade dashboard, Inter sans
#   phosphor                  - amber CRT terminal aesthetic
#   architecture              - 3-tier cluster topology diagram
#   transit                   - Deutsche Bahn departure board (dark only)
#   random                    - one of the four families, picked by date
# Phosphor, Professional and Architecture also accept '-light' / '-dark'
# to pin a colour mode (e.g. 'professional-light'). Bare 'auto', 'light',
# or 'dark' are kept as legacy aliases for the Phosphor sub-mode.
# URL ?theme=<key> overrides this. Invalid keys fall back to 'professional'.
DEFAULT_THEME=professional

# Optional override for the cluster label shown in headers and the
# browser tab. Useful for standalone Proxmox nodes (which don't expose
# a cluster name) or to give the dashboard a friendlier title. Leave
# empty to fall back to the auto-detected cluster name.
CLUSTER_NAME=

# Optional bearer token protecting /api/* and /metrics. When set, the
# dashboard URL must include ?token=<value> and any scraper must send
# 'Authorization: Bearer <value>'. Leave empty to disable auth.
DASHBOARD_TOKEN=

# Show the Proxmox host:port and dashboard URL in the dashboard footer.
# Leave false unless the monitor is physically private. Enables on-screen
# display of internal IPs. Default: false.
SHOW_HOST_INFO=false

# ==== Alert thresholds (percent) ============================================
# Node CPU
CPU_WARN=80
CPU_CRIT=95

# Node memory
MEM_WARN=85
MEM_CRIT=95

# Node root disk
DISK_WARN=85
DISK_CRIT=95

# Any active storage pool
STORAGE_WARN=85
STORAGE_CRIT=95
